# PaySentinel Environment Variables
# Copy to .env for local development (don't commit .env to Git)

# Dashboard Authentication
DASHBOARD_SECRET_CODE=paysentinel2005

# Session Security
PAYSENTINEL_SECRET_KEY=your-random-secret-key-here

# Optional: API Key Authentication
PAYSENTINEL_API_KEY=your-api-key-here

# Optional: Model Cache Signing
PAYSENTINEL_MODEL_CACHE_KEY=your-cache-signing-key

# Allowed Origins (for CORS)
PAYSENTINEL_ALLOWED_ORIGIN=https://yourdomain.com

# Production Mode
FLASK_DEBUG=false
FLASK_ENV=production

# Logging
LOG_LEVEL=info
