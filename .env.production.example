### Example production environment variables for Pay_Sentinel
# Copy this to `.env.production` and fill values before deploying.

FLASK_DEBUG=false
PORT=5000
PAYSENTINEL_API_KEY=changeme
ANTHROPIC_API_KEY=
WORKERS=2
WORKER_CLASS=gevent
LOG_LEVEL=info

# Optional settings
TZ=UTC
# If running behind a proxy, set the external host name
HOSTNAME=localhost
ANTHROPIC_API_KEY=your-anthropic-key
PAYSENTINEL_API_KEY=your-api-key
FLASK_ENV=production
LOG_LEVEL=warning
